MONGO_URI=mongodb://localhost:27017

# Mailtrap Email API (paste your token here)
# Sign up: https://mailtrap.io
# Go to API Tokens and copy the token here
MAILTRAP_API_KEY=your-mailtrap-api-token
MAILTRAP_API_URL=https://send.api.mailtrap.io/api/send
MAILTRAP_FROM_EMAIL=no-reply@ligbind.local
MAILTRAP_FROM_NAME=LigBind

# Optional explicit executable paths for docking tools (recommended on Windows)
OBABEL_PATH=C:/Program Files/OpenBabel-2.4.1/obabel.exe
VINA_PATH=C:/vina/vina.exe

# Optional SMTP fallback if you prefer SMTP instead of the API token
# SMTP_SERVER=smtp.mailtrap.io
# SMTP_PORT=587
# SENDER_EMAIL=your-mailtrap-username
# SENDER_PASSWORD=your-mailtrap-password
# SENDER_NAME=LigBind